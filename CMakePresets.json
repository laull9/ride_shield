{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "host-debug",
      "displayName": "Host Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/host-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "host-debug-source-deps",
      "displayName": "Host Debug (source deps)",
      "inherits": "host-debug",
      "cacheVariables": {
        "RIDESHIELD_ENABLE_SOURCE_DEPENDENCY_TARGETS": "ON"
      }
    },
    {
      "name": "host-windows-debug",
      "displayName": "Host Windows Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64"
      },
      "binaryDir": "${sourceDir}/build/host-windows-debug",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Debug"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "host-windows-debug-source-deps",
      "displayName": "Host Windows Debug (source deps)",
      "inherits": "host-windows-debug",
      "cacheVariables": {
        "RIDESHIELD_ENABLE_SOURCE_DEPENDENCY_TARGETS": "ON"
      }
    },
    {
      "name": "rk3588-arm64-release",
      "displayName": "RK3588 Arm64 Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/rk3588-arm64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/rk3588-aarch64.cmake",
        "RIDESHIELD_TARGET_ARCH": "arm64",
        "RIDESHIELD_ENABLE_SOURCE_DEPENDENCY_TARGETS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-host-debug",
      "configurePreset": "host-debug"
    },
    {
      "name": "build-host-windows-debug",
      "configurePreset": "host-windows-debug",
      "configuration": "Debug"
    },
    {
      "name": "deps-fetch-host",
      "configurePreset": "host-debug-source-deps",
      "targets": [
        "deps-fetch"
      ]
    },
    {
      "name": "deps-build-host-windows",
      "configurePreset": "host-windows-debug-source-deps",
      "configuration": "Debug",
      "targets": [
        "deps-build"
      ]
    },
    {
      "name": "deps-build-host",
      "configurePreset": "host-debug-source-deps",
      "targets": [
        "deps-build"
      ]
    },
    {
      "name": "build-rk3588-arm64-release",
      "configurePreset": "rk3588-arm64-release"
    }
  ]
}